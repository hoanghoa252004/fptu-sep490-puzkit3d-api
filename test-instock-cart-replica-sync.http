### Test Event-Driven Sync: InStock -> Cart Module Replicas
### This script tests the complete flow of data synchronization between modules

### Variables
@baseUrl = https://localhost:7001
@testProductId = {{createTestProduct.response.body.$}}
@testVariantId = {{createTestVariant.response.body.$}}
@testPriceId = {{createTestPrice.response.body.$}}
@testPriceDetailId = {{createTestPriceDetail.response.body.$}}

###############################################
# STEP 1: Create InStock Product
###############################################

### 1.1 Create Product
# @name createTestProduct
POST {{baseUrl}}/api/instock-products
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "slug": "pokemon-pikachu-001",
  "name": "Pokemon Pikachu Building Set",
  "totalPieceCount": 850,
  "difficultLevel": "Medium",
  "estimatedBuildTime": 150,
  "thumbnailUrl": "https://example.com/pikachu-thumb.jpg",
  "previewAsset": {
    "model3d": "https://example.com/pikachu.glb",
    "video": "https://example.com/pikachu-demo.mp4"
  },
  "topicId": "11111111-1111-1111-1111-111111111111",
  "assemblyMethodId": "22222222-2222-2222-2222-222222222222",
  "capabilityId": "33333333-3333-3333-3333-333333333333",
  "materialId": "44444444-4444-4444-4444-444444444444",
  "description": "Build your own Pikachu with detailed features including movable ears and tail",
  "isActive": true
}

### Expected: Product created, productId saved to variable

###############################################
# STEP 2: Create Product Variant
###############################################

### 2.1 Create Variant 1 - Yellow Pikachu (Standard)
# @name createTestVariant
POST {{baseUrl}}/api/instock-products/{{testProductId}}/variants
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "sku": "PKC-YEL-M",
  "color": "Yellow",
  "assembledLengthMm": 200,
  "assembledWidthMm": 150,
  "assembledHeightMm": 180,
  "isActive": true
}

### Expected: 
### - Variant created in InStock module
### - Domain Event: InstockProductVariantCreatedDomainEvent raised
### - Integration Event: InstockProductVariantCreatedIntegrationEvent published
### - Replica created in Cart module: in_stock_product_variant_replicas

### 2.2 Create Variant 2 - Red Pikachu (Limited Edition)
# @name createTestVariant2
POST {{baseUrl}}/api/instock-products/{{testProductId}}/variants
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "sku": "PKC-RED-M",
  "color": "Red",
  "assembledLengthMm": 200,
  "assembledWidthMm": 150,
  "assembledHeightMm": 180,
  "isActive": true
}

### 2.3 Verify Variant Created
GET {{baseUrl}}/api/instock-products/{{testProductId}}/variants/{{testVariantId}}
Authorization: Bearer YOUR_TOKEN_HERE

###############################################
# STEP 3: Create/Update Inventory
###############################################

### 3.1 Create/Update Inventory for Variant 1 (Initial Stock = 100)
PUT {{baseUrl}}/api/instock-products/{{testProductId}}/variants/{{testVariantId}}/inventory
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "quantity": 100
}

### Expected: 
### - Inventory created in InStock module
### - Domain Event: InstockInventoryCreatedDomainEvent raised
### - Integration Event: InstockInventoryChangedIntegrationEvent published
### - Replica created in Cart module: in_stock_inventory_replicas

### 3.2 Update Inventory for Variant 1 (Update to 250)
PUT {{baseUrl}}/api/instock-products/{{testProductId}}/variants/{{testVariantId}}/inventory
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "quantity": 250
}

### Expected: 
### - Inventory updated in InStock module
### - Domain Event: InstockInventoryUpdatedDomainEvent raised
### - Integration Event: InstockInventoryChangedIntegrationEvent published
### - Replica updated in Cart module: total_quantity = 250

### 3.3 Get Inventory
GET {{baseUrl}}/api/instock-products/{{testProductId}}/variants/{{testVariantId}}/inventory
Authorization: Bearer YOUR_TOKEN_HERE

### 3.4 Create Inventory for Variant 2
PUT {{baseUrl}}/api/instock-products/{{testProductId}}/variants/{{createTestVariant2.response.body.$}}/inventory
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "quantity": 50
}

