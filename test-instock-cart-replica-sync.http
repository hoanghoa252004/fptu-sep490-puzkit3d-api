# FINAL VERIFICATION - Complete Replica Check
###############################################

### Execute this comprehensive SQL query to verify all replicas:
/*
WITH variant_data AS (
    SELECT 
        v.id,
        v.sku,
        v.color,
        v.size,
        v.is_active as variant_active,
        i.total_quantity,
        i.updated_at as inventory_updated
    FROM cart.in_stock_product_variant_replicas v
    LEFT JOIN cart.in_stock_inventory_replicas i 
        ON i.in_stock_product_variant_id = v.id
    WHERE v.sku LIKE 'MF-UCS-%'
),
price_data AS (
    SELECT 
        vd.sku,
        p.name as price_name,
        p.priority,
        pd.unit_price,
        pd.is_active as price_active
    FROM variant_data vd
    JOIN cart.in_stock_product_price_detail_replicas pd 
        ON pd.in_stock_product_variant_id = vd.id
    JOIN cart.in_stock_price_replicas p 
        ON p.id = pd.in_stock_price_id
)
SELECT 
    vd.*,
    COALESCE(
        json_agg(
            json_build_object(
                'price_name', pd.price_name,
                'priority', pd.priority,
                'unit_price', pd.unit_price,
                'is_active', pd.price_active
            ) ORDER BY pd.priority DESC
        ) FILTER (WHERE pd.price_name IS NOT NULL),
        '[]'
    ) as prices
FROM variant_data vd
LEFT JOIN price_data pd ON pd.sku = vd.sku
GROUP BY vd.id, vd.sku, vd.color, vd.size, vd.variant_active, 
         vd.total_quantity, vd.inventory_updated
ORDER BY vd.sku;

Expected Result: Complete view of all replicas with prices
*/

