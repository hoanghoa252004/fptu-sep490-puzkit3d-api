### 8.1 SQL Query - Verify ProductVariant Replica
# Execute this in PostgreSQL client:
/*
SELECT 
    id,
    in_stock_product_id,
    sku,
    color,
    size,
    is_active,
    created_at,
    updated_at
FROM cart.in_stock_product_variant_replicas
WHERE sku = 'PKC-YEL-M';

Expected Result:
- id = {testVariantId}
- color = 'Golden Yellow' (after update)
- is_active = true
*/

### 8.2 SQL Query - Verify Inventory Replica
/*
SELECT 
    id,
    in_stock_product_variant_id,
    total_quantity,
    created_at,
    updated_at
FROM cart.in_stock_inventory_replicas
WHERE in_stock_product_variant_id = '{testVariantId}';

Expected Result:
- total_quantity = 180 (after update)
*/

### 8.3 SQL Query - Verify Price Replica
/*
SELECT 
    id,
    name,
    effective_from,
    effective_to,
    priority,
    is_active,
    created_at,
    updated_at
FROM cart.in_stock_price_replicas
WHERE name = 'Holiday Sale 2024';

Expected Result:
- Record exists with correct data
*/

### 8.4 SQL Query - Verify Price Detail Replica
/*
SELECT 
    id,
    in_stock_price_id,
    in_stock_product_variant_id,
    unit_price,
    is_active,
    created_at,
    updated_at
FROM cart.in_stock_product_price_detail_replicas
WHERE in_stock_product_variant_id = '{testVariantId}';

Expected Result:
- Multiple records (one for each price assigned to variant)
- unit_price for Holiday Sale = 279000 (after update)
- unit_price for New Year Sale = 249000
*/

### 8.5 SQL Query - Verify All Replicas for Testing
/*
-- Check all replicas for Pikachu variants
SELECT 'Variant Replicas' as table_name, COUNT(*) as count FROM cart.in_stock_product_variant_replicas
UNION ALL
SELECT 'Inventory Replicas', COUNT(*) FROM cart.in_stock_inventory_replicas
UNION ALL
SELECT 'Price Replicas', COUNT(*) FROM cart.in_stock_price_replicas
UNION ALL
SELECT 'Price Detail Replicas', COUNT(*) FROM cart.in_stock_product_price_detail_replicas;

Expected Result:
- Variant Replicas: 2 (Yellow + Red Pikachu)
- Inventory Replicas: 2 (one for each variant)
- Price Replicas: 2 (Holiday Sale + New Year Sale)
- Price Detail Replicas: 3 (2 for variant 1, 1 for variant 2)
*/

