### Variables
@baseUrl = https://localhost:7001
@productId = {{createProduct.response.body.$}}
@partId = {{createPart.response.body.$}}
@pieceId = {{createPiece.response.body.$}}

###############################################
# INSTOCK PRODUCT APIs TEST
###############################################

### 1. Create Instock Product
# @name createProduct
POST {{baseUrl}}/api/instock-products
Content-Type: application/json

{
  "slug": "test-product-001",
  "name": "Test Product 001",
  "totalPieceCount": 100,
  "difficultLevel": "Medium",
  "estimatedBuildTime": 120,
  "thumbnailUrl": "https://example.com/thumbnail.jpg",
  "previewAsset": {
    "model3d": "https://example.com/model.glb",
    "video": "https://example.com/video.mp4"
  },
  "topicId": "11111111-1111-1111-1111-111111111111",
  "assemblyMethodId": "22222222-2222-2222-2222-222222222222",
  "capabilityId": "33333333-3333-3333-3333-333333333333",
  "materialId": "44444444-4444-4444-4444-444444444444",
  "description": "This is a test product",
  "isActive": true
}

### 2. Get Product by ID
GET {{baseUrl}}/api/instock-products/{{productId}}

### 3. Update Product - Partial (only name and totalPieceCount)
PUT {{baseUrl}}/api/instock-products/{{productId}}
Content-Type: application/json

{
  "name": "Updated Product Name",
  "totalPieceCount": 150
}

### 4. Verify Update
GET {{baseUrl}}/api/instock-products/{{productId}}

### 5. Update Product - Multiple fields
PUT {{baseUrl}}/api/instock-products/{{productId}}
Content-Type: application/json

{
  "slug": "updated-product-001",
  "name": "Fully Updated Product",
  "totalPieceCount": 200,
  "difficultLevel": "Hard",
  "estimatedBuildTime": 180,
  "thumbnailUrl": "https://example.com/new-thumbnail.jpg",
  "previewAsset": {
    "model3d": "https://example.com/new-model.glb",
    "texture": "https://example.com/texture.png"
  },
  "description": "Completely updated product"
}

### 6. Delete Product (Soft Delete - IsActive = false)
DELETE {{baseUrl}}/api/instock-products/{{productId}}

### 7. Try to Delete Again (Should return 400 - Already Inactive)
DELETE {{baseUrl}}/api/instock-products/{{productId}}

### 8. Verify Product is Inactive
GET {{baseUrl}}/api/instock-products/{{productId}}

### 9. Activate Product (IsActive = true)
PATCH {{baseUrl}}/api/instock-products/{{productId}}/activate

### 10. Verify Product is Active
GET {{baseUrl}}/api/instock-products/{{productId}}

### 11. Try to Activate Again (Should return 400 - Already Active)
PATCH {{baseUrl}}/api/instock-products/{{productId}}/activate

###############################################
# PART APIs TEST
###############################################

### 12. Create Part 1
# @name createPart
POST {{baseUrl}}/api/instock-products/{{productId}}/parts
Content-Type: application/json

{
  "name": "Base Structure",
  "partType": "Foundation"
}

### 13. Get Part by ID (with all pieces)
GET {{baseUrl}}/api/instock-products/{{productId}}/parts/{{partId}}

### 14. Get All Parts for Product
GET {{baseUrl}}/api/instock-products/{{productId}}/parts

### 15. Update Part
PUT {{baseUrl}}/api/instock-products/{{productId}}/parts/{{partId}}
Content-Type: application/json

{
  "name": "Base Structure Updated",
  "partType": "Foundation Updated"
}

### 16. Verify Part Update
GET {{baseUrl}}/api/instock-products/{{productId}}/parts/{{partId}}

###############################################
# PIECE APIs TEST
###############################################

### 17. Create Piece 1 for Part 1
# @name createPiece
POST {{baseUrl}}/api/instock-products/{{productId}}/parts/{{partId}}/pieces
Content-Type: application/json

{
  "quantity": 50
}

### 18. Get Piece by ID
GET {{baseUrl}}/api/instock-products/{{productId}}/parts/{{partId}}/pieces/{{pieceId}}

### 19. Update Piece - Only Quantity
PUT {{baseUrl}}/api/instock-products/{{productId}}/parts/{{partId}}/pieces/{{pieceId}}
Content-Type: application/json

{
  "quantity": 75,
  "newPartId": null
}

### 20. Verify Piece Update
GET {{baseUrl}}/api/instock-products/{{productId}}/parts/{{partId}}/pieces/{{pieceId}}

### 21. Create Part 2 to test moving piece
# @name createPart2
POST {{baseUrl}}/api/instock-products/{{productId}}/parts
Content-Type: application/json

{
  "name": "Top Cover",
  "partType": "Cover"
}

### 22. Update Piece - Move to another Part
PUT {{baseUrl}}/api/instock-products/{{productId}}/parts/{{partId}}/pieces/{{pieceId}}
Content-Type: application/json

{
  "quantity": 100,
  "newPartId": "{{createPart2.response.body.$}}"
}

### 23. Verify Piece is moved (check Part 1 - should not have this piece)
GET {{baseUrl}}/api/instock-products/{{productId}}/parts/{{partId}}

### 24. Verify Piece is in Part 2
GET {{baseUrl}}/api/instock-products/{{productId}}/parts/{{createPart2.response.body.$}}

### 25. Delete Piece
DELETE {{baseUrl}}/api/instock-products/{{productId}}/parts/{{createPart2.response.body.$}}/pieces/{{pieceId}}

### 26. Verify Piece Deleted
GET {{baseUrl}}/api/instock-products/{{productId}}/parts/{{createPart2.response.body.$}}

### 27. Delete Part 2
DELETE {{baseUrl}}/api/instock-products/{{productId}}/parts/{{createPart2.response.body.$}}

### 28. Delete Part 1
DELETE {{baseUrl}}/api/instock-products/{{productId}}/parts/{{partId}}

### 29. Verify All Parts Deleted
GET {{baseUrl}}/api/instock-products/{{productId}}/parts

###############################################
# COMPLETE SCENARIO TEST
###############################################

### Scenario: Full Flow - Product -> Parts -> Pieces -> Operations

### S1. Create Product
# @name scenarioProduct
POST {{baseUrl}}/api/instock-products
Content-Type: application/json

{
  "slug": "lego-castle-001",
  "name": "Lego Castle Set",
  "totalPieceCount": 500,
  "difficultLevel": "Hard",
  "estimatedBuildTime": 180,
  "thumbnailUrl": "https://example.com/castle.jpg",
  "previewAsset": {
    "model3d": "https://example.com/castle.glb"
  },
  "topicId": "11111111-1111-1111-1111-111111111111",
  "assemblyMethodId": "22222222-2222-2222-2222-222222222222",
  "capabilityId": "33333333-3333-3333-3333-333333333333",
  "materialId": "44444444-4444-4444-4444-444444444444",
  "description": "Medieval castle building set",
  "isActive": true
}

### S2. Create Part 1 - Foundation
# @name scenarioPart1
POST {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}/parts
Content-Type: application/json

{
  "name": "Castle Foundation",
  "partType": "Base"
}

### S3. Create Part 2 - Walls
# @name scenarioPart2
POST {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}/parts
Content-Type: application/json

{
  "name": "Castle Walls",
  "partType": "Structure"
}

### S4. Create Piece 1 for Part 1
# @name scenarioPiece1
POST {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}/parts/{{scenarioPart1.response.body.$}}/pieces
Content-Type: application/json

{
  "quantity": 100
}

### S5. Create Piece 2 for Part 1
# @name scenarioPiece2
POST {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}/parts/{{scenarioPart1.response.body.$}}/pieces
Content-Type: application/json

{
  "quantity": 150
}

### S6. Create Piece 3 for Part 2
# @name scenarioPiece3
POST {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}/parts/{{scenarioPart2.response.body.$}}/pieces
Content-Type: application/json

{
  "quantity": 200
}

### S7. Get all parts with piece count (should show: Part1=250, Part2=200)
GET {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}/parts

### S8. Update Product Info
PUT {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}
Content-Type: application/json

{
  "name": "Lego Castle Set Deluxe",
  "totalPieceCount": 550,
  "description": "Medieval castle building set - Deluxe Edition"
}

### S9. Update Piece 1 quantity
PUT {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}/parts/{{scenarioPart1.response.body.$}}/pieces/{{scenarioPiece1.response.body.$}}
Content-Type: application/json

{
  "quantity": 120,
  "newPartId": null
}

### S10. Move Piece 2 from Part 1 to Part 2
PUT {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}/parts/{{scenarioPart1.response.body.$}}/pieces/{{scenarioPiece2.response.body.$}}
Content-Type: application/json

{
  "quantity": 180,
  "newPartId": "{{scenarioPart2.response.body.$}}"
}

### S11. Verify Part 1 (should have 1 piece: 120)
GET {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}/parts/{{scenarioPart1.response.body.$}}

### S12. Verify Part 2 (should have 2 pieces: 200 + 180 = 380)
GET {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}/parts/{{scenarioPart2.response.body.$}}

### S13. Deactivate Product
DELETE {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}

### S14. Verify Product is Inactive
GET {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}

### S15. Activate Product Again
PATCH {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}/activate

### S16. Delete a piece
DELETE {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}/parts/{{scenarioPart2.response.body.$}}/pieces/{{scenarioPiece3.response.body.$}}

### S17. Delete Part 2
DELETE {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}/parts/{{scenarioPart2.response.body.$}}

### S18. Final State - Get all parts (should only have Part 1 with 1 piece)
GET {{baseUrl}}/api/instock-products/{{scenarioProduct.response.body.$}}/parts
